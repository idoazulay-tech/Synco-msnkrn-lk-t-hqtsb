const SYSTEM_PROMPT = `אתה עוזר תכנון משימות חכם בעברית. המשתמש יתאר משימות שהוא צריך לבצע היום.
עליך לחלץ כל משימה בנפרד ולהחזיר JSON מובנה.

לכל משימה החזר:
- title: שם המשימה (עברית, קצר וברור)
- date: תאריך ISO (YYYY-MM-DD), ברירת מחדל: היום
- hour: שעת התחלה (0-23), null אם לא צוין
- minute: דקות (0, 15, 30, 45), null אם לא צוין
- duration: משך בדקות (ברירת מחדל: 30)
- priority: "high" / "medium" / "low" (הסק לפי דחיפות/חשיבות)
- flexibility: "fixed" (נעוץ בזמן) / "flexible" (גמיש) / "anytime" (בכל זמן)
- location: מיקום אם צוין (שם מקום, כתובת), null אם לא צוין
- notes: הערה קצרה אם יש מידע נוסף רלוונטי

החזר אך ורק JSON תקין בפורמט:
{ "tasks": [ { "title": "...", "date": "...", "hour": ..., "minute": ..., "duration": ..., "priority": "...", "flexibility": "...", "location": "...", "notes": "..." } ] }

חוקים:
- אם משתמש אומר "בוקר" = בין 8-10, "צהריים" = 12-13, "אחה"צ" = 14-16, "ערב" = 18-20
- אם משתמש אומר "דחוף" / "חשוב" = priority high
- פגישות/התחייבויות חיצוניות = flexibility fixed
- משימות עצמאיות = flexibility flexible
- אם צוין מיקום ("ב...", "ב-...", "אצל...", "ב..." + שם מקום) חלץ אותו ל-location
- "פגישה" ללא הגדרת משך = 60 דקות, "שיחה" = 30 דקות`;

router.post('/parse', async (req, res) => {
  try {
    const { text, todayDate, existingTasks, userId, dateIso, useAI } = req.body;

    if (!text || text.trim().length === 0) {
      return res.status(400).json({ error: 'text is required' });
    }

    const today = dateIso || todayDate || new Date().toISOString().split('T')[0];

    // ── Sprint 4ד: optional AI parse path ───────────────────────────────────
    if (useAI === true && AI_FEATURES.enabled && AI_FEATURES.parseEnabled) {
      try {
        const aiResult = await parsePlanningInputWithAI({
          text,
          dateIso: today,
          existingTasks: existingTasks ?? [],
        });

        if (aiResult.ok) {
          return res.json({
            ok: true,
            parser: 'ai_structured',
            tasks: aiResult.tasks,
            aiContext: {
              scenarioType: aiResult.scenarioType,
              anchors:      aiResult.anchors,
              questions:    aiResult.questions,
              assumptions:  aiResult.assumptions,
              warnings:     aiResult.warnings,
              confidence:   aiResult.confidence,
            },
          });
        }
        console.warn('[planner/parse] AI parse failed, falling back. reason:', aiResult.reason);
      } catch (aiErr: any) {
        console.warn('[planner/parse] AI parse threw, falling back:', aiErr?.message);
      }
    }

    // ── Existing parser (always works as fallback) ───────────────────────────
    const userMessage = `היום: ${today}
${existingTasks && existingTasks.length > 0 ? `\nמשימות קיימות ביומן:\n${existingTasks.map((t: any) => `- ${t.title} (${t.hour}:${String(t.minute || 0).padStart(2, '0')}, ${t.duration} דקות)`).join('\n')}` : ''}

המשתמש אמר:
"${text}"

חלץ את כל המשימות:`;

    let tasks: any[] = [];
    try {
      const content = await chatCompletion(SYSTEM_PROMPT, userMessage, {
        temperature: 0.3,
        jsonMode: true,
      });
      const parsed = JSON.parse(content || '{"tasks":[]}');
      tasks = parsed.tasks || [];
    } catch (fallbackErr: any) {
      console.warn('[planner/parse] chatCompletion fallback also failed:', fallbackErr?.message);
      tasks = [{ title: text.trim().slice(0, 100), duration: 30, priority: 'medium', flexibility: 'flexible' }];
    }

    res.json({ tasks, parser: 'rule_based' });
  } catch (error: any) {
    console.error('Planner parse error:', error);
    res.status(500).json({ error: 'Failed to parse tasks', details: error.message });
  }
});

// ── Sprint 4א: load user planning settings (safe, fire-and-forget on failure) ──
async function loadUserPlanningConfig(userId: string): Promise<PlanningConfig> {
  try {
    const record = await prisma.userSettings.findFirst();
    if (!record?.planningConfig) return { ...PLANNING_CONFIG_DEFAULTS };
    const raw = record.planningConfig as Record<string, unknown>;
    return {
      displayName:             (raw.displayName             as string)  ?? PLANNING_CONFIG_DEFAULTS.displayName,
      timezone:                (raw.timezone                as string)  ?? PLANNING_CONFIG_DEFAULTS.timezone,
      dayStart:                (raw.dayStart                as string)  ?? PLANNING_CONFIG_DEFAULTS.dayStart,
      dayEnd:                  (raw.dayEnd                  as string)  ?? PLANNING_CONFIG_DEFAULTS.dayEnd,
      planningBufferMinutes:   (raw.planningBufferMinutes   as number)  ?? PLANNING_CONFIG_DEFAULTS.planningBufferMinutes,
      transitionBufferMinutes: (raw.transitionBufferMinutes as number)  ?? PLANNING_CONFIG_DEFAULTS.transitionBufferMinutes,
      planningStyle:           (raw.planningStyle           as PlanningConfig['planningStyle'])  ?? PLANNING_CONFIG_DEFAULTS.planningStyle,
      themePreference:         (raw.themePreference         as PlanningConfig['themePreference']) ?? PLANNING_CONFIG_DEFAULTS.themePreference,
    };
  } catch {
    return { ...PLANNING_CONFIG_DEFAULTS };
  }
}

// POST /api/planner/schedule — suggest a schedule for the day (read-only, no DB writes)
router.post('/schedule', async (req: Request, res: Response) => {
  try {
    const {
      userId = 'default-user',
      date,
      tasks: bodyTasks,
      // Stage 3ב.1: No Past context from client
      nowIso,
      userTimeZone,
      timezoneOffsetMinutes,
    } = req.body;

    const dateIso: string = date || new Date().toISOString().split('T')[0];

    // Sprint 4א: load settings from DB; client dayStart/dayEnd used as fallback only
    const userCfg = await loadUserPlanningConfig(userId);
    const dayStart: string = userCfg.dayStart;
    const dayEnd:   string = userCfg.dayEnd;

    const startHour = parseInt(dayStart.split(':')[0], 10);
    const endHour   = parseInt(dayEnd.split(':')[0],   10);

    let rawTasks: any[];

    if (Array.isArray(bodyTasks) && bodyTasks.length > 0) {
      rawTasks = bodyTasks;
    } else {
      const dayStartDt = new Date(`${dateIso}T00:00:00.000Z`);
      const dayEndDt   = new Date(`${dateIso}T23:59:59.999Z`);
      rawTasks = await prisma.userTask.findMany({
        where: {
          userId,
          deletedAt: null,
          startTime: { gte: dayStartDt, lte: dayEndDt },
        },
      });
    }

    // ── Stage 3ב.1: No Past guard ─────────────────────────────────────────────
    const nowContext = buildNowContext(dateIso, nowIso, userTimeZone, timezoneOffsetMinutes);
    const noPastWarnings: string[] = [];

    // Separate fixed tasks that are already in the past
    const pastFixedTasks: any[] = [];
    const validRawTasks: any[] = [];

    for (const t of rawTasks) {
      if (isPastFixedTask(t, nowContext)) {
        pastFixedTasks.push(t);
        noPastWarnings.push(
          `"${t.title ?? t.id}" מוגדרת לזמן שכבר עבר היום ולא שובצה מחדש`
        );
      } else {
        validRawTasks.push(t);
      }
    }

    if (nowContext.isToday && noPastWarnings.length === 0 && pastFixedTasks.length === 0) {
      // Add info warning when we enforce no-past scheduling
      const earliestStr = getEarliestAllowedTimeString(nowContext);
      noPastWarnings.push(`לא שובצו משימות לפני ${earliestStr} — שיבוץ מהשעה הנוכחית בלבד`);
    }

    // ── Stage 3ב.1: Anchor context ────────────────────────────────────────────
    const anchorCtx = buildAnchorContext(validRawTasks, dateIso);

    // ── Learning context (שלב 3ב): fire-and-forget on failure ─────────────────
    let learningCtx: PlanningLearningContext | null = null;
    const learningWarnings: string[] = [];
    try {
      learningCtx = await buildPlanningLearningContext(userId, dateIso, validRawTasks);
    } catch (lcErr: any) {
      console.warn('[planner/schedule] learningContext failed (silent):', lcErr?.message);
      learningWarnings.push('לא הצלחנו לטעון היסטוריית למידה — הסידור חושב ללא הקשר');
    }

    // ── Stage 3ד: Duration suggestion context (fire-and-forget) ───────────────
    let durationSuggCtx: Awaited<ReturnType<typeof buildDurationSuggestionContext>> | null = null;
    const durationWarnings: string[] = [];
    try {
      durationSuggCtx = await buildDurationSuggestionContext(userId, validRawTasks, { dateIso });
    } catch (dsErr: any) {
      console.warn('[planner/schedule] durationSuggestions failed (silent):', dsErr?.message);
      durationWarnings.push('לא ניתן היה לחשב הצעות משך כרגע');
    }

    // Build a lookup: taskId → DurationSuggestion
    const durationSuggMap = new Map<string, DurationSuggestion>();
    if (durationSuggCtx) {
      for (const s of durationSuggCtx.suggestions) {
        if (s.taskId) durationSuggMap.set(s.taskId, s);
      }
    }

    // ── Priority scoring: score + sort validRawTasks before adapter ────────────
    const scored = scoreAndSort(validRawTasks, { referenceDate: dateIso, learningContext: learningCtx });

    // Build a lookup map: taskId → score data (including learning fields)
    const scoreMap = new Map(
      scored.map(s => [
        s.task.id as string,
        {
          score:           s.priorityScore,
          level:           s.priorityLevel,
          reasons:         s.priorityReasons,
          learningBoost:   s.learningBoost,
          learningReasons: s.learningReasons,
        },
      ])
    );

    // Pass sorted valid tasks to adapter (preserves fixed-first + score order)
    const scheduleTasks = adaptUserTasksToScheduleTasks(scored.map(s => s.task));

    // ── Stage 3ב.1: Apply No Past config ─────────────────────────────────────
    // Sprint 4א: apply planningStyle to buffer
    const effectiveBuffer = applyPlanningStyleBuffer(
      userCfg.planningBufferMinutes,
      userCfg.planningStyle
    );
    const planningStyleSummary = planningStyleSummaryHe(userCfg.planningStyle);

    const baseConfig: ScheduleConfig = {
      dayStartHour:   isNaN(startHour) ? 8  : startHour,
      dayEndHour:     isNaN(endHour)   ? 22 : endHour,
      bufferMinutes:  effectiveBuffer,
      minTaskMinutes: 10,
    };
    const config = applyNoPastSchedulingConfig(baseConfig, nowContext);

    const result = buildSchedule(dateIso, scheduleTasks, [], config);

    // ── Build scheduledTasks with Stage 3ב.1 schedulingContextReasons ─────────
    const scheduledTasks = result.blocks
      .filter(b => b.type === 'task' && b.refId)
      .map(b => {
        const task = scheduleTasks.find(t => t.id === b.refId);
        const rawTask = validRawTasks.find((t: any) => t.id === b.refId);
        const ps = scoreMap.get(b.refId!) ?? {
          score: 0, level: 'low', reasons: [],
          learningBoost: 0, learningReasons: [],
        };

        const startTimeStr = b.startTimeIso.substring(11, 16);
        const endTimeStr   = b.endTimeIso.substring(11, 16);

        // Stage 3ב.1: schedulingContextReasons
        const schedulingContextReasons = buildSchedulingContextReasons(
          b.refId!,
          b.title,
          startTimeStr,
          endTimeStr,
          anchorCtx,
          nowContext.nowIso,
        );

        // Stage 3ד: attach durationSuggestion if available for this task
        const durationSugg = b.refId ? durationSuggMap.get(b.refId) ?? null : null;

        return {
          id: b.refId!,
          title: b.title,
          startTime: startTimeStr,
          endTime:   endTimeStr,
          durationMinutes: task?.durationMinutes ?? rawTask?.duration ?? 0,
          priority: task?.urgency ?? rawTask?.priority ?? 'medium',
          priorityScore:   ps.score,
          priorityLevel:   ps.level,
          priorityReasons: ps.reasons,
          learningBoost:   ps.learningBoost,
          learningReasons: ps.learningReasons,
          schedulingContextReasons,
          reason: schedulingContextReasons[0] ?? 'שובץ בזמן פנוי מתאים',
          confidence: 0.8,
          // Stage 3ד: duration suggestion (null if no history or no significant delta)
          durationSuggestion: durationSugg
            ? {
                currentDurationMinutes:   durationSugg.currentDurationMinutes,
                suggestedDurationMinutes: durationSugg.suggestedDurationMinutes,
                confidence:               durationSugg.confidence,
                sampleSize:               durationSugg.sampleSize,
                averageActualDurationMinutes: durationSugg.averageActualDurationMinutes,
                averageDeltaMinutes:      durationSugg.averageDeltaMinutes,
                reason:                   durationSugg.reason,
              }
            : null,
        };
      });

    // ── Unscheduled tasks (validRawTasks that didn't get scheduled) ────────────
    const unscheduledTasks = result.unscheduledTasks.map(t => {
      const conflict = result.conflicts.find(c => c.entityId === t.id);
      return {
        id: t.id,
        title: t.title,
        reason: conflict?.message ?? 'לא נמצא חלון זמן מתאים',
      };
    });

    // Past fixed tasks are also "unscheduled"
    const pastFixedUnscheduled = pastFixedTasks.map(t => ({
      id: t.id ?? '',
      title: t.title ?? '',
      reason: 'המשימה מוגדרת לזמן שכבר עבר היום',
    }));

    const dayLoadMinutes = result.blocks
      .filter(b => b.type === 'task')
      .reduce((sum, b) => {
        const ms = new Date(b.endTimeIso).getTime() - new Date(b.startTimeIso).getTime();
        return sum + Math.round(ms / 60000);
      }, 0);

    const allWarnings = [
      ...result.conflicts.map(c => c.message),
      ...learningWarnings,
      ...(learningCtx?.warnings ?? []),
      ...noPastWarnings,
      ...anchorCtx.warnings,
      ...durationWarnings,
    ];

    // Stage 3ב.1: summaries for client
    const nowContextSummary = {
      isToday: nowContext.isToday,
      earliestAllowedTime: getEarliestAllowedTimeString(nowContext),
      nowIso: nowContext.nowIso,
    };

    const anchorContextSummary = {
      anchorsDetected: anchorCtx.anchors.length,
      preparationLinksDetected: anchorCtx.preparationLinks.length,
      anchors: anchorCtx.anchors.map(a => ({
        title: a.title,
        startTime: a.startTime.substring(11, 16),
        anchorType: a.anchorType,
      })),
      warnings: anchorCtx.warnings,
    };

    res.json({
      ok: true,
      date: dateIso,
      userId,
      scheduledTasks,
      unscheduledTasks: [...unscheduledTasks, ...pastFixedUnscheduled],
      warnings: allWarnings,
      summary: {
        totalTasks:       scheduleTasks.length,
        scheduledCount:   scheduledTasks.length,
        unscheduledCount: unscheduledTasks.length + pastFixedUnscheduled.length,
        dayLoadMinutes,
      },
      learningContextSummary: learningCtx
        ? {
            enabled:           learningCtx.enabled,
            lookbackDays:      learningCtx.lookbackDays,
            topCompletionHours: learningCtx.topCompletionHours,
            warnings:          learningCtx.warnings,
          }
        : null,
      // Stage 3ב.1
      nowContextSummary,
      anchorContextSummary,
      // Stage 3ד: duration suggestion summary
      durationSuggestionSummary: durationSuggCtx
        ? {
            enabled:         durationSuggCtx.enabled,
            lookbackDays:    durationSuggCtx.lookbackDays,
            suggestionCount: durationSuggCtx.suggestions.length,
            warnings:        durationSuggCtx.warnings,
          }
        : null,
      // Sprint 4א: planning settings summary
      planningStyleSummary,
      planningSettingsApplied: {
        dayStart:              userCfg.dayStart,
        dayEnd:                userCfg.dayEnd,
        planningBufferMinutes: userCfg.planningBufferMinutes,
        effectiveBuffer,
        planningStyle:         userCfg.planningStyle,
        transitionBuffer:      userCfg.transitionBufferMinutes,
      },
    });
  } catch (error: any) {
    console.error('POST /api/planner/schedule error:', error);
    res.status(500).json({ error: 'Failed to schedule tasks', details: error.message });
  }
});

// POST /api/planner/apply-schedule — atomically save confirmed schedule to DB
router.post('/apply-schedule', async (req: Request, res: Response) => {
  try {
    const { userId = 'default-user', date, items } = req.body;

    if (!date || typeof date !== 'string') {
      return res.status(400).json({ ok: false, error: 'date is required', updatedCount: 0 });
    }
    if (!Array.isArray(items) || items.length === 0) {
      return res.status(400).json({ ok: false, error: 'items must be a non-empty array', updatedCount: 0 });
    }

    // Validate and parse each item
    const validItems: { taskId: string; startTime: Date; endTime: Date }[] = [];
    const skipped: { id: string; reason: string }[] = [];

    for (const item of items) {
      if (!item.taskId || !item.startTime || !item.endTime) {
        skipped.push({ id: item.taskId ?? '?', reason: 'שדות חסרים (taskId / startTime / endTime)' });
        continue;
      }
      // startTime/endTime arrive as "HH:MM" — combine with date
      const startIso = `${date}T${item.startTime}:00.000Z`;
      const endIso   = `${date}T${item.endTime}:00.000Z`;
      const startDt  = new Date(startIso);
      const endDt    = new Date(endIso);

      if (isNaN(startDt.getTime()) || isNaN(endDt.getTime()) || endDt <= startDt) {
        skipped.push({ id: item.taskId, reason: 'פורמט זמן לא תקין' });
        continue;
      }
      validItems.push({ taskId: item.taskId, startTime: startDt, endTime: endDt });
    }

    if (validItems.length === 0) {
      return res.status(400).json({ ok: false, error: 'לא נמצאו פריטים תקינים לשמירה', updatedCount: 0, skipped });
    }

    // Fetch tasks that belong to userId, are not deleted, and are not completed
    const taskIds = validItems.map(i => i.taskId);
    const eligible = await prisma.userTask.findMany({
      where: { id: { in: taskIds }, userId, deletedAt: null, status: { not: 'completed' } },
      select: { id: true },
    });
    const eligibleIds = new Set(eligible.map(t => t.id));

    const toUpdate = validItems.filter(i => eligibleIds.has(i.taskId));
    const notEligible = validItems
      .filter(i => !eligibleIds.has(i.taskId))
      .map(i => ({ id: i.taskId, reason: 'לא נמצאה משימה זו, או שהיא הושלמה / נמחקה' }));

    // Atomic Prisma transaction — all or nothing
    const updatedRecords = await prisma.$transaction(
      toUpdate.map(item =>
        prisma.userTask.update({
          where: { id: item.taskId },
          data: {
            startTime: item.startTime,
            endTime:   item.endTime,
            duration:  Math.round((item.endTime.getTime() - item.startTime.getTime()) / 60000),
          },
        })
      )
    );

    // ── Log schedule_applied event (fire-and-forget, never breaks response) ──
    prisma.learningEvent.create({
      data: {
        userId,
        eventType: 'schedule_applied',
        source:    'planner/apply-schedule',
        dateIso:   date,
        metadata:  {
          updatedCount: updatedRecords.length,
          taskIds: updatedRecords.map(r => r.id),
          date,
        },
      },
    }).catch((err: any) => {
      console.warn('[planner] schedule_applied event log failed (silent):', err?.message);
    });

    res.json({
      ok: true,
      date,
      userId,
      updatedCount: updatedRecords.length,
      updatedTasks: updatedRecords.map(r => ({
        id:        r.id,
        title:     r.title,
        startTime: r.startTime.toISOString(),
        endTime:   r.endTime.toISOString(),
      })),
      skipped: [...skipped, ...notEligible],
      warnings: [],
    });
  } catch (error: any) {
    console.error('POST /api/planner/apply-schedule error:', error);
    res.status(500).json({
      ok: false,
      error: 'שגיאה בשמירת הסידור. לא בוצע שום שינוי.',
      updatedCount: 0,
      warnings: [error.message],
    });
  }
});

// POST /api/planner/commit-draft-schedule
// Atomic: creates real UserTasks from drafts + sets their start/end times
router.post('/commit-draft-schedule', async (req: Request, res: Response) => {
  try {
    const {
      userId = 'default-user',
      date,
      draftTasks,
      scheduledItems,
      timezoneOffsetMinutes,
      userTimeZone,
    } = req.body;

    // ── Validation ────────────────────────────────────────────────────────────
    if (!date || typeof date !== 'string') {
      return res.status(400).json({ ok: false, error: 'date is required' });
    }
    if (!Array.isArray(draftTasks) || draftTasks.length === 0) {
      return res.status(400).json({ ok: false, error: 'draftTasks must be a non-empty array' });
    }
    if (!Array.isArray(scheduledItems)) {
      return res.status(400).json({ ok: false, error: 'scheduledItems must be an array' });
    }

    // Build a lookup: draftId → scheduled times
    const scheduleMap = new Map<string, { startTime: string; endTime: string }>();
    for (const item of scheduledItems) {
      if (item.draftId && item.startTime && item.endTime) {
        scheduleMap.set(item.draftId, {
          startTime: item.startTime,
          endTime:   item.endTime,
        });
      }
    }

    // Verify every draft has a draftId present in scheduledItems (or has own times)
    const missingSchedule: string[] = [];
    for (const draft of draftTasks) {
      if (!scheduleMap.has(draft.id) && !draft.startTime) {
        missingSchedule.push(draft.id);
      }
    }
    if (missingSchedule.length > 0) {
      return res.status(400).json({
        ok: false,
        error: `draft tasks missing schedule: ${missingSchedule.join(', ')}`,
      });
    }

    // ── Build Prisma create data ───────────────────────────────────────────────
    const createDataList: {
      draftId: string;
      data: Parameters<typeof prisma.userTask.create>[0]['data'];
    }[] = [];

    for (const draft of draftTasks) {
      if (!draft.title) continue;

      const scheduled = scheduleMap.get(draft.id);
      const startHHMM = scheduled?.startTime ?? draft.startTime ?? '09:00';
      const endHHMM   = scheduled?.endTime   ?? draft.endTime   ?? '09:30';

      const draftDate = draft.dateIso ?? date;
      const startIso  = `${draftDate}T${startHHMM}:00.000Z`;
      const endIso    = `${draftDate}T${endHHMM}:00.000Z`;

      const startDt = new Date(startIso);
      const endDt   = new Date(endIso);

      if (isNaN(startDt.getTime()) || isNaN(endDt.getTime()) || endDt <= startDt) {
        return res.status(400).json({
          ok: false,
          error: `invalid time range for draft "${draft.title}": ${startHHMM}–${endHHMM}`,
        });
      }

      const durationMinutes = Math.round((endDt.getTime() - startDt.getTime()) / 60000);
      const newId = `task_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;

      createDataList.push({
        draftId: draft.id,
        data: {
          id:          newId,
          userId,
          title:       draft.title,
          description: draft.description ?? null,
          location:    draft.location ?? null,
          startTime:   startDt,
          endTime:     endDt,
          duration:    durationMinutes,
          status:      'pending',
          priority:    draft.priority ?? 'medium',
          flexibility: draft.flexibility ?? 'flexible',
          isAllDay:    false,
          isRecurring: false,
          excludedDates: [],
          tagsJson:    [],
          historyJson: [],
          createdFromJson: { source: 'user_input', tsIso: new Date().toISOString() },
        },
      });
    }

    if (createDataList.length === 0) {
      return res.status(400).json({ ok: false, error: 'no valid tasks to create' });
    }

    // ── Atomic Prisma $transaction: all or nothing ─────────────────────────────
    const createdRecords = await prisma.$transaction(
      createDataList.map(({ data }) => prisma.userTask.create({ data }))
    );

    // ── Build draftId → real taskId map ───────────────────────────────────────
    const draftToTaskMap: Record<string, string> = {};
    createDataList.forEach(({ draftId }, idx) => {
      draftToTaskMap[draftId] = createdRecords[idx].id;
    });

    // ── Fire-and-forget: log task_created learning events ─────────────────────
    for (const record of createdRecords) {
      prisma.learningEvent.create({
        data: {
          userId,
          taskId:            record.id,
          eventType:         'task_created',
          source:            'planner/commit-draft-schedule',
          dateIso:           date,
          taskTitleSnapshot: record.title,
          metadata:          { via: 'planning-draft', date },
        },
      }).catch((err: any) => {
        console.warn('[commit-draft-schedule] task_created event failed (silent):', err?.message);
      });
    }

    // ── Fire-and-forget: log schedule_applied event ───────────────────────────
    prisma.learningEvent.create({
      data: {
        userId,
        eventType: 'schedule_applied',
        source:    'planner/commit-draft-schedule',
        dateIso:   date,
        metadata:  {
          createdCount: createdRecords.length,
          taskIds:      createdRecords.map(r => r.id),
          date,
        },
      },
    }).catch((err: any) => {
      console.warn('[commit-draft-schedule] schedule_applied event failed (silent):', err?.message);
    });

    res.json({
      ok: true,
      createdCount: createdRecords.length,
      createdTasks: createdRecords.map(r => ({
        id:        r.id,
        title:     r.title,
        startTime: r.startTime.toISOString(),
        endTime:   r.endTime.toISOString(),
      })),
      draftToTaskMap,
    });
  } catch (error: any) {
    console.error('POST /api/planner/commit-draft-schedule error:', error);
    res.status(500).json({
      ok: false,
      error: 'שגיאה ביצירת המשימות. לא נשמר שום דבר.',
      details: error.message,
    });
  }
});

// ══════════════════════════════════════════════════════════════════════════════
// Sprint 4ד: POST /api/planner/day-command-preview
// Natural language day command → AI intent → preview only (NO DB writes)
// ══════════════════════════════════════════════════════════════════════════════
router.post('/day-command-preview', async (req: Request, res: Response) => {
  try {
    const {
      userId = 'default-user',
      dateIso,
      text,
      selectedTaskIds,
      nowIso,
      useAI = true,
    } = req.body;

    if (!dateIso || typeof dateIso !== 'string') {
      return res.status(400).json({ ok: false, error: 'dateIso is required' });
    }
    if (!text || typeof text !== 'string' || text.trim().length === 0) {
      return res.status(400).json({ ok: false, error: 'text is required' });
    }

    if (!useAI || !AI_FEATURES.enabled || !AI_FEATURES.dayCommandEnabled) {
      return res.json({
        ok: false,
        mode: 'preview_only',
        reason: !AI_FEATURES.enabled ? 'ai_disabled' : 'day_command_disabled',
        message: 'AI day commands are not enabled. Set SYNCO_AI_ENABLED=true and SYNCO_AI_DAY_COMMAND_ENABLED=true.',
      });
    }

    // Load existing tasks for the day
    const dayStart = new Date(`${dateIso}T00:00:00.000Z`);
    const dayEnd   = new Date(`${dateIso}T23:59:59.999Z`);
    const dbTasks  = await prisma.userTask.findMany({
      where: { userId, deletedAt: null, startTime: { gte: dayStart, lte: dayEnd } },
      select: { id: true, title: true, status: true, startTime: true, endTime: true, priority: true, flexibility: true, duration: true },
    });

    const existingTasks = dbTasks.map(t => ({
      id:        t.id,
      title:     t.title,
      status:    t.status,
      startTime: t.startTime?.toISOString() ?? null,
      endTime:   t.endTime?.toISOString() ?? null,
    }));

    // Load user settings
    const settings = await loadUserPlanningConfig(userId);

    // Call AI reasoning service (no DB writes inside)
    const aiResult = await interpretDayCommandWithAI({
      userId,
      dateIso,
      text: text.trim(),
      nowIso:          nowIso ?? new Date().toISOString(),
      settings:        settings as unknown as Record<string, unknown>,
      existingTasks,
      selectedTaskIds: Array.isArray(selectedTaskIds) ? selectedTaskIds : [],
    });

    if (!aiResult.ok) {
      return res.json({
        ok: false,
        mode: 'preview_only',
        reason: aiResult.reason,
        message: 'AI could not process this command. Please try again or rephrase.',
        questions: 'questions' in aiResult ? aiResult.questions : [],
        warnings:  'warnings'  in aiResult ? aiResult.warnings  : [],
      });
    }

    // needsClarification path
    if ('needsClarification' in aiResult && aiResult.needsClarification) {
      return res.json({
        ok: true,
        mode: 'preview_only',
        needsClarification: true,
        questions:   aiResult.questions ?? [],
        assumptions: aiResult.assumptions ?? [],
        warnings:    aiResult.warnings ?? [],
        commandIntent: {
          commandType: aiResult.commandType,
          targetScope: aiResult.targetScope,
          confidence:  aiResult.confidence,
        },
      });
    }

    // Build proposedChanges summary for UI
    const proposedChanges = aiResult.operations.map(op => ({
      type:                  op.type,
      operationId:           op.operationId,
      targetTaskId:          op.targetTaskId ?? null,
      title:                 op.targetTaskTitle ?? op.newTask?.['title'] ?? null,
      before:                op.targetTaskId
                               ? existingTasks.find(t => t.id === op.targetTaskId) ?? null
                               : null,
      after:                 op.patch ?? op.newTask ?? null,
      recurrence:            op.recurrence ?? null,
      reason:                op.reason,
      riskLevel:             op.riskLevel,
      requiresExplicitConfirm: op.requiresExplicitConfirm,
    }));

    return res.json({
      ok: true,
      mode: 'preview_only',
      commandIntent: {
        commandType:          aiResult.commandType,
        targetScope:          aiResult.targetScope,
        dateIso:              aiResult.dateIso ?? dateIso,
        confidence:           aiResult.confidence,
        requiresConfirmation: aiResult.requiresConfirmation,
      },
      proposedChanges,
      questions:   aiResult.questions   ?? [],
      assumptions: aiResult.assumptions ?? [],
      warnings:    [...(aiResult.warnings ?? []), ...('validatorWarnings' in aiResult ? (aiResult as any).validatorWarnings ?? [] : [])],
    });
  } catch (error: any) {
    console.error('POST /api/planner/day-command-preview error:', error);
    res.status(500).json({ ok: false, error: 'Failed to preview day command', details: error.message });
  }
});

// ══════════════════════════════════════════════════════════════════════════════
// Sprint 4ד: POST /api/planner/apply-day-command
// Accepts ONLY pre-validated operations from day-command-preview
// No raw text accepted — runs Prisma $transaction
// ══════════════════════════════════════════════════════════════════════════════
router.post('/apply-day-command', async (req: Request, res: Response) => {
  try {
    const {
      userId = 'default-user',
      dateIso,
      operations,
      confirm,
    } = req.body;

    if (confirm !== true) {
      return res.status(400).json({ ok: false, error: 'confirm=true is required for apply-day-command' });
    }
    if (!dateIso || typeof dateIso !== 'string') {
      return res.status(400).json({ ok: false, error: 'dateIso is required' });
    }
    if (!Array.isArray(operations) || operations.length === 0) {
      return res.status(400).json({ ok: false, error: 'operations must be a non-empty array' });
    }

    // Re-load day tasks from DB for safety re-validation
    const dayStart = new Date(`${dateIso}T00:00:00.000Z`);
    const dayEnd   = new Date(`${dateIso}T23:59:59.999Z`);
    const dbTasks  = await prisma.userTask.findMany({
      where: { userId, deletedAt: null, startTime: { gte: dayStart, lte: dayEnd } },
    });
    const taskMap = new Map(dbTasks.map(t => [t.id, t]));

    const now = new Date();
    const applied: string[] = [];
    const skipped: { operationId: string; reason: string }[] = [];

    // Build transaction operations
    const txOps: Parameters<typeof prisma.$transaction>[0] extends Array<infer U> ? U[] : never[] = [];

    for (const op of operations) {
      const opId = op.operationId ?? 'unknown';

      // Allowed types only
      const allowedTypes = ['create_task', 'update_task', 'delete_task', 'duplicate_task', 'reschedule_task'];
      if (!allowedTypes.includes(op.type)) {
        skipped.push({ operationId: opId, reason: `operation type "${op.type}" requires separate handling or is read-only` });
        continue;
      }

      if (op.targetTaskId && !taskMap.has(op.targetTaskId)) {
        skipped.push({ operationId: opId, reason: `targetTaskId "${op.targetTaskId}" no longer exists` });
        continue;
      }

      if (op.type === 'delete_task') {
        if (!op.targetTaskId) {
          skipped.push({ operationId: opId, reason: 'delete_task missing targetTaskId' });
          continue;
        }
        (txOps as any[]).push(prisma.userTask.update({
          where: { id: op.targetTaskId },
          data:  { deletedAt: now },
        }));
        applied.push(opId);
        continue;
      }

      if (op.type === 'update_task' || op.type === 'reschedule_task') {
        if (!op.targetTaskId || !op.patch) {
          skipped.push({ operationId: opId, reason: 'update/reschedule missing targetTaskId or patch' });
          continue;
        }
        // No past scheduling guard
        if (op.patch.startTime) {
          const newStart = new Date(op.patch.startTime);
          if (!isNaN(newStart.getTime()) && newStart < now) {
            skipped.push({ operationId: opId, reason: 'reschedule would place task in the past — blocked' });
            continue;
          }
        }
        const allowedPatchKeys = ['title', 'startTime', 'endTime', 'duration', 'priority', 'flexibility', 'location', 'description', 'notes'];
        const safePatch: Record<string, unknown> = {};
        for (const k of allowedPatchKeys) {
          if (op.patch[k] !== undefined) safePatch[k] = op.patch[k];
        }
        if (safePatch.startTime) safePatch.startTime = new Date(safePatch.startTime as string);
        if (safePatch.endTime)   safePatch.endTime   = new Date(safePatch.endTime as string);
        (txOps as any[]).push(prisma.userTask.update({ where: { id: op.targetTaskId }, data: safePatch }));
        applied.push(opId);
        continue;
      }

      if (op.type === 'create_task') {
        const nt = op.newTask;
        if (!nt?.title) {
          skipped.push({ operationId: opId, reason: 'create_task missing newTask.title' });
          continue;
        }
        const startDt = nt.startTime ? new Date(nt.startTime) : null;
        const endDt   = nt.endTime   ? new Date(nt.endTime)   : null;
        if (startDt && !isNaN(startDt.getTime()) && startDt < now) {
          skipped.push({ operationId: opId, reason: 'create_task would place task in the past — blocked' });
          continue;
        }
        const newId = `task_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
        (txOps as any[]).push(prisma.userTask.create({ data: {
          id:          newId,
          userId,
          title:       String(nt.title),
          description: nt.description ? String(nt.description) : null,
          location:    nt.location    ? String(nt.location)    : null,
          startTime:   startDt && !isNaN(startDt.getTime()) ? startDt : new Date(`${dateIso}T09:00:00.000Z`),
          endTime:     endDt   && !isNaN(endDt.getTime())   ? endDt   : new Date(`${dateIso}T09:30:00.000Z`),
          duration:    nt.duration ? Number(nt.duration) : 30,
          status:      'pending',
          priority:    nt.priority    ?? 'medium',
          flexibility: nt.flexibility ?? 'flexible',
          isAllDay:    false,
          isRecurring: false,
          excludedDates: [],
          tagsJson:    [],
          historyJson: [],
          createdFromJson: { source: 'day_command_ai', tsIso: now.toISOString() },
        }}));
        applied.push(opId);
        continue;
      }

      if (op.type === 'duplicate_task') {
        const src = op.targetTaskId ? taskMap.get(op.targetTaskId) : null;
        if (!src) {
          skipped.push({ operationId: opId, reason: 'duplicate_task source not found' });
          continue;
        }
        const newId = `task_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
        const targetDate = op.patch?.['dateIso'] ? String(op.patch['dateIso']) : dateIso;
        const startDt = new Date(src.startTime ? `${targetDate}T${src.startTime.toISOString().split('T')[1]}` : `${targetDate}T09:00:00.000Z`);
        const endDt   = new Date(src.endTime   ? `${targetDate}T${src.endTime.toISOString().split('T')[1]}`   : `${targetDate}T09:30:00.000Z`);
        (txOps as any[]).push(prisma.userTask.create({ data: {
          id:          newId,
          userId,
          title:       src.title,
          description: src.description,
          location:    src.location,
          startTime:   startDt,
          endTime:     endDt,
          duration:    src.duration,
          status:      'pending',
          priority:    src.priority,
          flexibility: src.flexibility,
          isAllDay:    src.isAllDay,
          isRecurring: false,
          excludedDates: [],
          tagsJson:    [],
          historyJson: [],
          createdFromJson: { source: 'day_command_duplicate', tsIso: now.toISOString() },
        }}));
        applied.push(opId);
        continue;
      }
    }

    if (txOps.length === 0) {
      return res.json({ ok: true, appliedCount: 0, skipped, message: 'No operations were applied.' });
    }

    await prisma.$transaction(txOps as any[]);

    // Fire-and-forget learning event
    prisma.learningEvent.create({
      data: {
        userId,
        eventType: 'schedule_applied',
        source:    'planner/apply-day-command',
        dateIso,
        metadata:  { appliedCount: applied.length, operationIds: applied, skipped },
      },
    }).catch((err: any) => console.warn('[apply-day-command] learning event failed (silent):', err?.message));

    res.json({ ok: true, appliedCount: applied.length, applied, skipped });
  } catch (error: any) {
    console.error('POST /api/planner/apply-day-command error:', error);
    res.status(500).json({ ok: false, error: 'Failed to apply day command. Nothing was changed.', details: error.message });
  }
});

export default router;
