{
  "expo": {
    "name": "MA - המכולל",
    "slug": "ma-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3b82f6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ma.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3b82f6"
      },
      "package": "com.ma.mobile",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "ma-mobile",
    "extra": {
      "apiUrl": "https://your-replit-url.replit.dev",
      "router": {},
      "eas": {
        "projectId": "7aa5e459-5be5-4291-825a-d8197e57264c"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "sdkVersion": "54.0.0"
  }
}
